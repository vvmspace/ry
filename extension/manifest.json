{
  "manifest_version": 3,
  "name": "LinkedIn Label Autofill",
  "version": "1.0.0",
  "description": "Autofills LinkedIn URL into inputs whose label mentions LinkedIn.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://jobs.ashbyhq.com/*",
    "http://tma.kingofthehill.pro:4040/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LinkedIn Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jobs.ashbyhq.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}