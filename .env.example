USER_DIR=./userdir
PORT=4040
# Optional: serve frontend from same port (default: frontend/.output/public)
# STATIC_DIR=frontend/.output/public
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE=remoteyeah
REMOTEYEAH_SEARCH_URLS=https://remoteyeah.com/remote-nestjs-jobs,https://remoteyeah.com/remote-nodejs-jobs
STOP_WORDS=ruby,python,dotnet
# CV generation (optional; defaults: dark_calendly, gemini-3.1-pro-preview)
# CV_TEMPLATE=dark_calendly
# CV_MODEL=gemini-3.1-pro-preview
# Profile links for fast copy (optional)
LINKEDIN_PROFILE=https://www.linkedin.com/in/your-profile/
GITHUB_PROFILE=https://github.com/your-username
# Deployment (optional)
USER_HOST=user@server.com
REMOTE_PATH=/path/to/deploy