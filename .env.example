USER_DIR=./userdir
PORT=4040
# Optional: serve frontend from same port (default: frontend/.output/public)
# STATIC_DIR=frontend/.output/public
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
# Optional direct URI fallback for environments where mongodb+srv DNS SRV lookups fail.
# Example for Atlas direct URI (without +srv), include hosts/replicaSet/tls from Atlas UI:
# MONGODB_CONNECTION_STRING_DIRECT=mongodb://host1:27017,host2:27017,host3:27017/?replicaSet=...&tls=true&authSource=admin
# Optional custom DNS resolvers (comma-separated) used before Mongo connect.
# Useful when local resolver blocks SRV queries for mongodb+srv.
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_DATABASE=remoteyeah
REMOTEYEAH_SEARCH_URLS=https://remoteyeah.com/remote-nestjs-jobs,https://remoteyeah.com/remote-nodejs-jobs
STOP_WORDS=ruby,python,dotnet
# CV generation (optional; defaults: dark_calendly, gemini-3.1-pro-preview)
# CV_TEMPLATE=dark_calendly
# CV_MODEL=gemini-3.1-pro-preview
# Profile links for fast copy (optional)
LINKEDIN_PROFILE=https://www.linkedin.com/in/your-profile/
GITHUB_PROFILE=https://github.com/your-username
# Deployment (optional)
USER_HOST=user@server.com
REMOTE_PATH=/path/to/deploy

# Worker interval guards (in seconds, optional)
# Skip jobsListWorker if last success/error was less than N seconds ago
# PENDING_SUCCESS_INTERVAL=3600
# PENDING_ERROR_INTERVAL=300
# Skip jobPageWorker if last success/error was less than N seconds ago
# SAVED_SUCCESS_INTERVAL=60
# SAVED_ERROR_INTERVAL=120
# Skip cvGenerationWorker if last success/error was less than N seconds ago
# GENERATED_SUCCESS_INTERVAL=60
# GENERATED_ERROR_INTERVAL=120

FIRST_NAME=Ivan
LAST_NAME=Ivanov
PHONE=+1234567890
